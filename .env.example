# Whisker (Litter-Robot app) account credentials — REQUIRED.
# Same email/password you use to log into the Whisker mobile app.
WHISKER_EMAIL=you@example.com
WHISKER_PASSWORD=your-whisker-password

# ---- Optional tuning (defaults shown) ----
# Run the container as this host user/group — set it to whoever owns your
# DATA_DIR (find the values with `id -u` and `id -g`) so the app can write the
# DB without re-owning your folders. Unset = the image's non-root user.
# PUID=1000
# PGID=1000
# Where to store the SQLite database (your permanent history).
# Unset = a Docker-managed named volume. Set a host path to keep the DB in a
# folder you control so it's easy to back up — e.g. on a Synology, alongside
# your other container data:
# DATA_DIR=/volume1/docker/catdash
# How often to pull fresh data from Whisker, in hours.
# COLLECT_INTERVAL_HOURS=6
# Minimum minutes between manual "Collect now" runs (the scheduled collection
# is unaffected). Each collection logs into Whisker with your credentials, so
# this floor keeps anyone who can reach the dashboard from hammering Whisker
# with logins. 0 disables the cooldown.
# REFRESH_COOLDOWN_MINUTES=10
# Host port to expose the dashboard on.
# PORT=8080
# Timezone for log timestamps. By default the container follows the HOST
# timezone (docker-compose.yml bind-mounts /etc/localtime); set this to override.
# TZ=America/New_York
# Max activity-history rows to request per robot per run (first run is a large
# backfill; later runs are incremental).
# ACTIVITY_LIMIT=50000
# Max per-pet weight measurements to request per run.
# WEIGHT_LIMIT=5000
# Days of insight (daily clean-cycle) history to request.
# INSIGHT_DAYS=365

# ---- Optional: live status + remote control (OFF by default) ----
# Catdash is read-only out of the box. Set this to true to add a "Robots" panel
# with LIVE STATUS and REMOTE CONTROL of your units — start a clean cycle, night
# light, wait time, panel lock, power, feeder snack, etc. The dashboard has NO
# login, so anyone who can reach it can then control your robots: only enable
# this on a trusted network (e.g. behind Tailscale/LAN). When false, the control
# endpoints don't exist and the dashboard stays exactly as read-only as before.
# CONTROLS_ENABLED=false

# ---- Optional: Tailscale access (docker-compose.tailscale.yml) ----
# Reach the dashboard over your tailnet at https://catdash.<your-tailnet>.ts.net.
# Naming convention: TS_* are settings the Tailscale daemon reads (you only ever
# set TS_AUTHKEY); TAILSCALE_* are host filesystem paths bound into the container,
# which you can relocate here.
#
# REUSABLE auth key from the admin console (Settings -> Keys). Only used on the
# first start; revoke it afterward. Also enable HTTPS Certificates in the admin
# console (DNS tab) or Tailscale serve won't start.
# TS_AUTHKEY=tskey-auth-xxxxxxxxxxxx
# Host dir for Tailscale node state. Unset = a Docker-managed named volume; set a
# host path to keep it alongside your other container data.
# TAILSCALE_STATE_DIR=/volume1/docker/catdash/ts-state
# Host path to the serve config file. Unset = ./tailscale/serve.json (shipped in
# the repo); set it to point at a file you manage elsewhere.
# TAILSCALE_SERVE_CONFIG=/volume1/docker/catdash/serve.json
