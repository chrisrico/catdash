# Whisker (Litter-Robot app) account credentials — REQUIRED.
# Same email/password you use to log into the Whisker mobile app.
WHISKER_EMAIL=you@example.com
WHISKER_PASSWORD=your-whisker-password

# ---- Optional tuning (defaults shown) ----
# How often to pull fresh data from Whisker, in hours.
# COLLECT_INTERVAL_HOURS=6
# Host port to expose the dashboard on.
# PORT=8080
# Timezone for the container (affects logs / local-day grouping).
# TZ=America/New_York
# Max activity-history rows to request per robot per run.
# ACTIVITY_LIMIT=1000
# Max per-pet weight measurements to request per run.
# WEIGHT_LIMIT=500
# Days of insight (daily clean-cycle) history to request.
# INSIGHT_DAYS=30
