# Whisker (Litter-Robot app) account credentials — REQUIRED.
# Same email/password you use to log into the Whisker mobile app.
WHISKER_EMAIL=you@example.com
WHISKER_PASSWORD=your-whisker-password

# ---- Optional tuning (defaults shown) ----
# Where to store the SQLite database (your permanent history).
# Unset = a Docker-managed named volume. Set a host path to keep the DB in a
# folder you control so it's easy to back up — e.g. on a Synology, alongside
# your other container data:
# DATA_DIR=/volume1/docker/catdash
# How often to pull fresh data from Whisker, in hours.
# COLLECT_INTERVAL_HOURS=6
# Host port to expose the dashboard on.
# PORT=8080
# Timezone for log timestamps. By default the container follows the HOST
# timezone (docker-compose.yml bind-mounts /etc/localtime); set this to override.
# TZ=America/New_York
# Max activity-history rows to request per robot per run (first run is a large
# backfill; later runs are incremental).
# ACTIVITY_LIMIT=50000
# Max per-pet weight measurements to request per run.
# WEIGHT_LIMIT=5000
# Days of insight (daily clean-cycle) history to request.
# INSIGHT_DAYS=365
